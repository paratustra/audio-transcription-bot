# Copy to .env and fill in. See the README for details.

# --- Twilio (required to validate inbound requests and send replies) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
# Your WhatsApp sender, with or without the "whatsapp:" prefix.
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- Whisper ---
# Model size: tiny | base | small | medium | large (bigger = slower, more accurate)
WHISPER_MODEL=small
# Optional: force a language (ISO code, e.g. "es"). Leave blank to auto-detect.
WHISPER_LANGUAGE=

# --- Webhook / networking ---
# Behind a proxy or ngrok, set this to the public HTTPS base URL Twilio calls,
# e.g. https://your-app.ngrok.io — it makes signature validation reliable.
PUBLIC_BASE_URL=
# Number of proxies in front of the app (ProxyFix). 0 disables it.
TRUSTED_PROXIES=1

# --- Behavior ---
# true = ack immediately and send the transcription in a second message.
ASYNC_REPLY=false
# Reject media larger than this many bytes (default 26214400 = 25 MB).
MAX_AUDIO_BYTES=26214400
# Seconds to wait when downloading media (default 60).
DOWNLOAD_TIMEOUT=60

# --- Dev server ---
DEBUG=false
PORT=5000
